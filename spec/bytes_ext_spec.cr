require "./spec_helper"

macro it_converts_bytes(type, value, native_bytes, little_endian_bytes, big_endian_bytes)
  describe {{ type }} do
    describe "#to_bytes" do
      it { {{ value }}.to_bytes.should eq({{ native_bytes }}) }
    end

    describe "#to_ne_bytes" do
      it { {{ value }}.to_ne_bytes.should eq({{ native_bytes }}) }
    end

    describe "#to_le_bytes" do
      it { {{ value }}.to_le_bytes.should eq({{ little_endian_bytes }}) }
    end

    describe "#to_be_bytes" do
      it { {{ value }}.to_be_bytes.should eq({{ big_endian_bytes }}) }
    end

    describe ".from_bytes" do
      it { {{ type }}.from_bytes({{ native_bytes }}).should eq({{ value }}) }
    end

    describe ".from_ne_bytes" do
      it { {{ type }}.from_ne_bytes({{ native_bytes }}).should eq({{ value }}) }
    end

    describe ".from_le_bytes" do
      it { {{ type }}.from_le_bytes({{ little_endian_bytes }}).should eq({{ value }}) }
    end

    describe ".from_be_bytes" do
      it { {{ type }}.from_be_bytes({{ big_endian_bytes }}).should eq({{ value }}) }
    end
  end
end

it_converts_bytes Int8,
  0x12_i8,
  Bytes[0x12],
  Bytes[0x12],
  Bytes[0x12]

it_converts_bytes Int16,
  0x1234_i16,
  Bytes[0x34, 0x12],
  Bytes[0x34, 0x12],
  Bytes[0x12, 0x34]

it_converts_bytes Int32,
  0x12345678_i32,
  Bytes[0x78, 0x56, 0x34, 0x12],
  Bytes[0x78, 0x56, 0x34, 0x12],
  Bytes[0x12, 0x34, 0x56, 0x78]

describe Int32 do
  describe ".from_bytes" do
    it "reports the expected and actual byte count" do
      expect_raises(ArgumentError, "Expected exactly 4 bytes, got 3") do
        Int32.from_bytes(Bytes[0x78, 0x56, 0x34])
      end
    end
  end
end

